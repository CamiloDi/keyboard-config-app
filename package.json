{
    "name": "keyboard-config-app",
    "version": "1.0.0",
    "description": "Configurator for Pro Micro Macropad",
    "author": "Camilo Diaz",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "postinstall": "electron-builder install-app-deps",
        "dist": "electron-builder",
        "dist:mac": "electron-builder --mac",
        "dist:win": "electron-builder --win",
        "dist:all": "electron-builder -mwl",
        "test": "jest --coverage",
        "test:watch": "jest --watch"
    },
    "build": {
        "appId": "com.camilodiaz.keyboardconfig",
        "productName": "Keyboard Config",
        "directories": {
            "buildResources": "assets",
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "renderer.js",
            "index.html",
            "assets/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.utilities",
            "icon": "assets/icon.icns"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Keyboard Config"
        }
    },
    "dependencies": {
        "@serialport/parser-readline": "^12.0.0",
        "serialport": "^12.0.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3",
        "jest": "^29.6.1",
        "jest-environment-jsdom": "^29.6.1"
    }
}